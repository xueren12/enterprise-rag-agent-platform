# Embedding provider
# hash: deterministic offline/test fallback
# sentence_transformer: real local embedding model, requires sentence-transformers
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Vector store
# chroma is preferred. If chromadb is unavailable, the app falls back to local JSON vectors.
VECTOR_STORE_TYPE=chroma
CHROMA_COLLECTION_NAME=enterprise_rag_docs

# LLM provider
# mock: offline/test mode, no API key required
# deepseek/openai: OpenAI-compatible chat API
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=30
